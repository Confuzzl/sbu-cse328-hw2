#include "app/extra/scene.h"

#define GLM_ENABLE_EXPERIMENTAL
#include <glm/gtx/norm.hpp>

#include "app/app.h"

SceneExtra::Ball::Ball(const glm::vec2 pos, const float rad,
                       const glm::vec2 vel)
    : pos{pos}, rad{rad}, vel{vel} {}
SceneExtra::Ball SceneExtra::Ball::operator+(const glm::vec2 t) const {
  return {pos + t, rad, vel};
}
bool SceneExtra::Ball::intersects(const Ball &that) const {
  const float rr = rad + that.rad;
  const float rr2 = rr * rr;
  const float diff2 = glm::distance2(pos, that.pos);
  return diff2 < rr2;
}

int SceneExtra::Organism::ID_COUNT = 0;
SceneExtra::Organism::Organism(const glm::vec2 pos, const glm::vec2 vel,
                               const Species species, const float size,
                               const float minimumReproduceSize,
                               const float minimumReproduceAge)
    : Ball{pos, RADIUS_SIZE_RATIO * std::sqrt(size), vel}, species{species},
      size{size}, minimumReproduceSize{minimumReproduceSize}, age{0},
      minimumReproduceAge{minimumReproduceAge} {}
void SceneExtra::Organism::addSize(const float s) {
  size += s;
  rad = RADIUS_SIZE_RATIO * std::sqrt(size);
}
SceneExtra::Organism
SceneExtra::Organism::createChild(const glm::vec2 offset) const {
  return Organism{pos + offset,
                  random_vec2() * random_float(1.0f, 100.0f),
                  species,
                  size * random_float(0.1f, 0.25f),
                  minimumReproduceSize * random_float(0.95f, 1.05f),
                  minimumReproduceAge * random_float(0.95f, 1.05f)};
}
SceneExtra::Organism SceneExtra::Organism::reproduce() {
  const auto offset = random_vec2() * rad / 2.0f;
  Organism out = createChild(offset);
  *this = createChild(-offset);
  return out;
}

SceneExtra::SceneExtra() : config{{10, 100}, {100, 100}, {110, 120}, {2, 3}} {
  organisms.reserve(MAX_ORGANISMS);
}
void SceneExtra::update(const float dt) {
  std::vector<int> readyToReproduce{};
  std::vector<int> readyToDie{};
  for (auto i = 0; i < organisms.size(); i++) {
    auto &organism = organisms[i];

    // organism.addSize(10 * dt);
    organism.age += dt;

    if (organism.readyToReproduce()) {
      readyToReproduce.emplace_back(i);
    }

    glm::vec2 &pos = organism.pos, &vel = organism.vel;
    const float rad = organism.rad;
    const auto step = vel * dt;
    const auto nextPos = pos + step;

    // window checks
    for (int i = 0; i < 2; i++) {
      if (nextPos[i] - rad < 0 || nextPos[i] + rad > app().framebufferSize[i]) {
        vel[i] *= -1;
      }
    }

    for (auto j = 0; j < organisms.size(); j++) {
      auto &that = organisms[j];
      if (i == j)
        continue;

      // push them out of each other
      const float rr = organism.rad + that.rad;
      const glm::vec2 dist = that.pos - organism.pos;
      const float diff = glm::length(dist) - rr;
      if (diff < 0) {
        organism.pos -= diff * 0.6f;
        that.pos += diff * 0.6f;
      }

      if ((organism + step).intersects(that)) {
        const auto v1 = vel, x1 = pos;
        const auto v2 = that.vel, x2 = that.pos;

        // https://en.wikipedia.org/wiki/Elastic_collision#Two-dimensional_collision_with_two_moving_objects
        const auto diff = x1 - x2;
        const auto frac = glm::dot(v1 - v2, diff) / glm::length2(diff);
        const auto prod = frac * diff;

        vel = v1 - prod;
        that.vel = v2 + prod;
        if (organism.species != that.species) {
          if (organism.size == that.size)
            continue;
          auto large = organism.size > that.size ? i : j,
               small = organism.size < that.size ? i : j;

          // organisms[large].size += organisms[small].size;
          organisms[large].addSize(organisms[small].size);
          // organisms[small].size = 0;
          readyToDie.emplace_back(small);
        }
      }
    }

    pos += vel * dt;
  }

  // for (const auto i : readyToReproduce) {
  //   if (organisms.size() == MAX_ORGANISMS)
  //     break;
  //   organisms.emplace_back(organisms[i].reproduce());
  //   (organisms[i].species == Species::A ? countA : countB)++;
  // }

  std::vector<Organism> temp;
  temp.reserve(organisms.size() - readyToDie.size());
  for (auto i = 0; i < organisms.size(); i++) {
    bool dies = false;
    for (auto j = 0; j < readyToDie.size(); j++) {
      if (i == j) {
        dies = true;
        break;
      }
    }
    if (!dies) {
      (organisms[i].species == Species::A ? countA : countB)--;
      temp.emplace_back(organisms[i]);
    }
  }
  organisms = std::move(temp);
}

void SceneExtra::spawn(const Species s) {
  // organisms.emplace_back(Cursor::gamePos, glm::vec2{}, s, 100.f, 1000000.f,
  //                        1000000.f);
  organisms.emplace_back(
      Cursor::gamePos,
      random_vec2() * random_float(config.speedRange.x, config.speedRange.y), s,
      random_float(config.sizeRange.x, config.sizeRange.y),
      random_float(config.minimumReproduceSizeRange.x,
                   config.minimumReproduceSizeRange.y),
      random_float(config.minimumReproduceAgeRange.x,
                   config.minimumReproduceAgeRange.y));
}
void SceneExtra::onClick() {
  switch (state) {
  case State::SPECIES_A: {
    if (organisms.size() < MAX_ORGANISMS) {
      spawn(Species::A);
      countA++;
    }
    break;
  }
  case State::SPECIES_B: {
    if (organisms.size() < MAX_ORGANISMS) {
      spawn(Species::B);
      countB++;
    }
    break;
  }
  case State::DELETE: {
    break;
  }
  }
}

void SceneExtra::clear() { organisms.clear(); }