#include "app/extra/simulation.h"

#include <imgui.h>

#include "app/app.h"

SimulationExtra::SimulationExtra()
    : Simulation{{{
                      {GLFW_KEY_1, Key{[](const double) {
                         app().simExtra.scene.state =
                             SceneExtra::State::SPECIES_A;
                       }}},
                      {GLFW_KEY_2, Key{[](const double) {
                         app().simExtra.scene.state =
                             SceneExtra::State::SPECIES_B;
                       }}},
                      {GLFW_KEY_3, Key{[](const double) {
                         app().simExtra.scene.state = SceneExtra::State::DELETE;
                       }}},
                  },
                  [](GLFWwindow *window, int button, int action, int mods) {
                    if (action == GLFW_PRESS) {
                      app().simExtra.scene.onClick();
                    }
                  },
                  [](GLFWwindow *window, double xoffset, double yoffset) {}}} {}

void SimulationExtra::update(const float dt) { scene.update(dt); }

void SimulationExtra::renderImpl(const float dt) { renderer.render(dt); }
void SimulationExtra::drawSideBarImpl() {
  auto &scene = app().simExtra.scene;

  auto foo = fmt::format("balls: ({}A+{}B):{}/{}", scene.countA, scene.countB,
                         scene.organisms.size(), SceneExtra::MAX_ORGANISMS);
  ImGui::Text(foo.c_str());

  if (scene.organisms.size() > 0) {
    foo = fmt::format(
        "size={:.1f}/{:.1f} age={:.1f}/{:.1f}", scene.organisms[0].size,
        scene.organisms[0].minimumReproduceSize, scene.organisms[0].age,
        scene.organisms[0].minimumReproduceAge);
    ImGui::Text(foo.c_str());
  }

  ImGui::SeparatorText("Tools");
  struct ButtonData {
    const char *name;
  };
  static const std::map<SceneExtra::State, ButtonData> buttonData{
      {SceneExtra::State::SPECIES_A, {"1: Species A"}},
      {SceneExtra::State::SPECIES_B, {"2: Species B"}},
      {SceneExtra::State::DELETE, {"3: Delete"}},
  };
  static constexpr auto button = [](auto name) {
    static constexpr ImVec2 SIZE{200, 75};
    ImGui::SetCursorPosX((ImGui::GetWindowSize().x - SIZE.x) / 2);
    return ImGui::Button(name, SIZE);
  };
  for (const auto [state, data] : buttonData) {
    if (scene.state == state) {
      ImGui::BeginDisabled();
      button(data.name);
      ImGui::EndDisabled();
    } else {
      if (button(data.name)) {
        scene.state = state;
      }
    }
  }

  if (button("CLEAR ALL")) {
    scene.clear();
  }

  ImGui::SeparatorText("Organism parameters");

  ImGui::InputFloat2("speed", &scene.config.speedRange.x);
  ImGui::InputFloat2("size", &scene.config.sizeRange.x);
  ImGui::InputFloat2("min reprod size",
                     &scene.config.minimumReproduceSizeRange.x);
  ImGui::InputFloat2("min reprod age",
                     &scene.config.minimumReproduceAgeRange.x);
}